{
  "manifest_version": 3,
  "name": "GitHub Enhancements — Retry Failed Builds",
  "version": "1.0.0",
  "description": "Adds a Retry button next to failed GitHub Actions checks on PR pages.",
  "content_scripts": [
    {
      "matches": ["https://github.com/*/pull/*"],
      "js": ["src/content.js"],
      "css": ["src/styles.css"],
      "run_at": "document_idle",
      "world": "MAIN"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
